{
  "name": "purely-personal",
  "version": "0.1.0",
  "description": "Purely Personal — your AI on your laptop. Private by default. Nothing ever leaves your machine.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "sync-html": "cp ../workshop.html ./workshop.html",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "ollama",
    "local-ai",
    "privacy",
    "workshop",
    "electron"
  ],
  "author": "danielpaulai",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.danielpaulai.purely-personal",
    "productName": "Purely Personal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "workshop.html",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  }
}
